# ─── Sanity CMS ────────────────────────────────────────────
# Create a project at https://sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Read token from Sanity project settings → API → Tokens
SANITY_API_TOKEN=your_read_token

# ─── Supabase ───────────────────────────────────────────────
# Create a project at https://supabase.com
# Run the SQL in lib/supabase/schema.sql to create the inquiries table
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Telegram Bot ───────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram
# 2. Start a conversation with your bot or add it to a group
# 3. Get the chat_id by messaging the bot and checking:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── Email (Resend) ─────────────────────────────────────────
# Create an account at https://resend.com
# Add and verify your sending domain
RESEND_API_KEY=re_your_api_key
OWNER_EMAIL=your@email.com
FROM_EMAIL=notifications@dacha-tv.com

# ─── Admin dashboard ────────────────────────────────────────
# Single password for the /admin route
# Use a strong password in production
ADMIN_PASSWORD=choose_a_strong_password

# ─── Site ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://dacha-tv.com
# From Google Analytics 4 → Data Streams → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
